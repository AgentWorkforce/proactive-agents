{
  "name": "@cloud/replay-harness",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "replay": "./src/index.ts"
  },
  "scripts": {
    "replay": "node --import tsx ./src/index.ts",
    "test": "node ../../node_modules/vitest/vitest.mjs run test/equivalence.test.ts test/replay-smoke.test.ts test/corpus-schema.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
